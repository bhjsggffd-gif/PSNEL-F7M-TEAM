    {'id': '4388873518', 'password': 'AllFF_VIP9EPCCU8RV'},
    {'id': '4388871767', 'password': 'AllFF_VIPFP79Z3NOV'},
    {'id': '4388871410', 'password': 'AllFF_VIP7BRSBMYZH'}
]

def STaRT_AccoUnT(account):
    """تشغيل حساب فردي"""
    try:
        print(f"[INFO] Starting account: {account['id']}")
        xCLF(account['id'], account['password'])
    except Exception as e:
        print(f"[ERROR] Account {account['id']} failed: {e}")
        time.sleep(10)
        STaRT_AccoUnT(account)

def StarT_SerVer():
    """تشغيل جميع الحسابات"""
    print("[INFO] Starting all accounts...")
    threads = []
    
    for account in xA:
        thread = threading.Thread(target=STaRT_AccoUnT, args=(account,))
        thread.daemon = True
        threads.append(thread)
        thread.start()
        time.sleep(3)
    
    for thread in threads:
        thread.join()

def MeMoRy_CmD():
    """مراقبة استخدام الذاكرة"""
    while True:
        memory_usage = psutil.Process().memory_percent()
        if memory_usage > 80:
            print(f"[WARNING] High memory usage: {memory_usage}%. Restarting...")
            ResTarT_BoT()
        time.sleep(60)

# تشغيل مراقبة الذاكرة
memory_thread = threading.Thread(target=MeMoRy_CmD, daemon=True)
memory_thread.start()

# تطبيق Flask
app = Flask(__name__)

@app.route('/msg', methods=['GET'])
def send_message():
    """إرسال رسائل إلى السرب"""
    teamcode = request.args.get('teamcode')
    msg = request.args.get('msg')
    
    if not teamcode or not msg:
        return jsonify({"success": False, "error": "معامل teamcode و msg مطلوبين"}), 400
    
    with connected_clients_lock:
        if not connected_clients:
            return jsonify({"success": False, "error": "لا توجد حسابات متصلة"}), 503
        
        first_client = list(connected_clients.values())[0]
        print(f"[API] Getting squad info for: {teamcode}")
        team_data = first_client.GeTinFoSqMsG(teamcode)
        
        if not team_data.get("success"):
            return jsonify({
                "success": False,
                "error": "فشل في جلب معلومات السكواد",
                "reason": team_data.get("reason", "سبب غير معروف"),
                "teamcode": teamcode
            }), 400
        
        success = first_client.SeNd_SpaM_MsG(
            team_data.get("OwNer_UiD"),
            team_data.get("ChaT_CoDe"),
            msg,
            count=100
        )
        
        if success:
            return jsonify({
                "success": True,
                "message": f"تم إرسال الرسائل بنجاح إلى السكواد: {teamcode}",
                "details": {
                    "owner_uid": team_data.get("OwNer_UiD"),
                    "chat_code": team_data.get("ChaT_CoDe"),
                    "squad_code": team_data.get("SQuAD_CoDe", ""),
                    "squad_name": team_data.get("Squad_Name", ""),
                    "squad_members": team_data.get("Squad_Members", 0),
                    "message_sent": msg
                }
            })
        else:
            return jsonify({"success": False, "error": "فشل في إرسال الرسائل"}), 500

@app.route('/status', methods=['GET'])
def get_status():
    """الحصول على حالة البوت"""
    with connected_clients_lock:
        return jsonify({
            "success": True,
            "connected_accounts": len(connected_clients),
            "accounts": list(connected_clients.keys()),
            "status": "running"
        }), 200

@app.route('/squad_info', methods=['GET'])
def get_squad_info():
    """جلب معلومات السرب فقط"""
    teamcode = request.args.get('teamcode')
    
    if not teamcode:
        return jsonify({"success": False, "error": "معامل teamcode مطلوب"}), 400
    
    with connected_clients_lock:
        if not connected_clients:
            return jsonify({"success": False, "error": "لا توجد حسابات متصلة"}), 503
        
        first_client = list(connected_clients.values())[0]
        team_data = first_client.GeTinFoSqMsG(teamcode)
        
        if not team_data.get("success"):
            return jsonify({
                "success": False,
                "error": "فشل في جلب معلومات السكواد",
                "reason": team_data.get("reason", "سبب غير معروف"),
                "teamcode": teamcode
            }), 400
        
        return jsonify({
            "success": True,
            "teamcode": teamcode,
            "owner_uid": team_data.get("OwNer_UiD"),
            "chat_code": team_data.get("ChaT_CoDe"),
            "squad_code": team_data.get("SQuAD_CoDe", ""),
            "squad_name": team_data.get("Squad_Name", ""),
            "squad_members": team_data.get("Squad_Members", 0)
        }), 200

@app.route('/check_squad', methods=['GET'])
def check_squad():
    """التحقق من صحة رمز السرب"""
    teamcode = request.args.get('teamcode')
    
    if not teamcode:
        return jsonify({"success": False, "error": "معامل teamcode مطلوب"}), 400
    
    with connected_clients_lock:
        if not connected_clients:
            return jsonify({
                "success": False,
                "error": "لا توجد حسابات متصلة",
                "suggestion": "انتظر حتى يكتمل اتصال البوت بالخادم"
            }), 503
        
        first_client = list(connected_clients.values())[0]
        
        if not hasattr(first_client, 'CliEnts2') or not first_client.CliEnts2:
            return jsonify({
                "success": False,
                "error": "الاتصال الثانوي غير موجود",
                "suggestion": "انتظر حتى يكتمل اتصال البوت بالخادم"
            }), 503
        
        team_data = first_client.GeTinFoSqMsG(teamcode)
        
        return jsonify({
            "success": team_data.get("success", False),
            "teamcode": teamcode,
            "message": "رمز السكواد صالح" if team_data.get("success") else "رمز السكواد غير صالح أو لا يمكن الوصول إليه",
            "details": team_data if team_data.get("success") else {"error": team_data.get("reason")}
        }), 200 if team_data.get("success") else 400

if __name__ == '__main__':
    print("=" * 50)
    print("Starting FreeFire Bot with Improved Timeout Handling")
    print("=" * 50)
    
    # تشغيل البوت
    bot_thread = threading.Thread(target=StarT_SerVer, daemon=True)
    bot_thread.start()
    
    # انتظار اتصال البوت
    print("[INFO] Waiting for bot to connect...")
    time.sleep(20)
    
    # تشغيل الخادم
    print("[INFO] Starting Flask server on port 7860...")
    print("[INFO] Available endpoints:")
    print("  - GET /msg?teamcode=CODE&msg=MESSAGE")
    print("  - GET /status")
    print("  - GET /squad_info?teamcode=CODE")
    print("  - GET /check_squad?teamcode=CODE")
    print("=" * 50)
    
    app.run(host='0.0.0.0', port=7860, debug=False, threaded=True)