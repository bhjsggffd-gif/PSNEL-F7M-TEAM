class xCLF():

    def __init__(xSeT, id, password):
        xSeT.id = id
        xSeT.password = password
        xSeT.thread_pool = ThreadPoolExecutor(max_workers=20)
        xSeT.active_threads = []
        xSeT.thread_timeout = 30
        xSeT.InPuTMsG = ""
        xSeT.DeCode_CliEnt_Uid = ""
        xSeT.max_retries = 3
        xSeT.retry_count = 0
        xSeT.last_timeout_log = 0  # لتتبع آخر مرة تم فيها طباعة رسالة مهلة

        with connected_clients_lock:
            connected_clients[xSeT.id] = xSeT
        
        xSeT.GeNToKeNLogin()                        

    def GeTinFoSqMsG(xSeT, teamcode):
        """جلب معلومات السرب مع تحسين معالجة المهلات"""
        try:
            if hasattr(xSeT, 'CliEnts2') and xSeT.CliEnts2:
                # تنظيف البيانات القديمة
                xSeT.DaTa2 = b"" 
                
                # إرسال طلب الانضمام للسرب
                print(f"[INFO] Account {xSeT.id}: Sending JoinSq for teamcode: {teamcode}")
                xSeT.CliEnts2.send(JoinSq(teamcode, xSeT.key, xSeT.iv))
                
                # انتظار الرد مع مهلة 15 ثانية
                start_wait = time.time()
                timeout = 15
                response_received = False
                last_progress_log = start_wait
                
                while time.time() - start_wait < timeout:
                    try:
                        # استخدام مهلة قصيرة للقراءة المتكررة
                        xSeT.CliEnts2.settimeout(1)
                        chunk = xSeT.CliEnts2.recv(8192)
                        
                        if chunk:
                            xSeT.DaTa2 += chunk
                            hex_data = xSeT.DaTa2.hex()
                            
                            # التحقق من وجود الرد المناسب
                            if '0500' in hex_data:
                                try:
                                    # استخراج البيانات المشفرة
                                    encoded_data = extract_encrypted_data(hex_data)
                                    if encoded_data:
                                        decoded_data = DeCode_PackEt(encoded_data)
                                        dT = json.loads(decoded_data)
                                        
                                        # استخراج البيانات
                                        OwNer_UiD, SQuAD_CoDe, ChaT_CoDe = GeTSQDaTa(dT)
                                        
                                        # استخراج معلومات إضافية
                                        Squad_Name = ""
                                        Squad_Members = 0
                                        
                                        if '5' in dT and 'data' in dT['5']:
                                            data_field = dT['5']['data']
                                            if '2' in data_field:
                                                Squad_Name = str(data_field['2'].get('data', ''))
                                            if '6' in data_field:
                                                Squad_Members = data_field['6'] if isinstance(data_field['6'], int) else 0
                                        
                                        if OwNer_UiD and ChaT_CoDe:
                                            print(f"[SUCCESS] Account {xSeT.id}: Retrieved squad info successfully")
                                            # إرسال طلب الخروج
                                            xSeT.CliEnts2.send(ExitSq('000000', xSeT.key, xSeT.iv))
                                            time.sleep(0.2)
                                            
                                            response_received = True
                                            return {
                                                "success": True, 
                                                "OwNer_UiD": OwNer_UiD, 
                                                "SQuAD_CoDe": SQuAD_CoDe,
                                                "ChaT_CoDe": ChaT_CoDe,
                                                "Squad_Name": Squad_Name,
                                                "Squad_Members": Squad_Members
                                            }
                                except Exception as decode_error:
                                    print(f"[WARNING] Account {xSeT.id}: Decode error: {decode_error}")
                                    continue
                    
                    except socket.timeout:
                        # طباعة رسالة مهلة كل 5 ثوانٍ فقط لتجنب التكرار المزعج
                        current_time = time.time()
                        if current_time - xSeT.last_timeout_log > 5:
                            print(f"[TIMEOUT] Account {xSeT.id}: Waiting for squad response... ({int(current_time - start_wait)}s)")
                            xSeT.last_timeout_log = current_time
                        continue
                    
                    except socket.error as sock_err:
                        print(f"[ERROR] Account {xSeT.id}: Socket error: {sock_err}")
                        break
                    
                    # طباعة تقدم كل 3 ثوانٍ
                    current_time = time.time()
                    if current_time - last_progress_log > 3 and not response_received:
                        print(f"[PROGRESS] Account {xSeT.id}: Still waiting for squad {teamcode}... ({int(current_time - start_wait)}s)")
                        last_progress_log = current_time
                
                if not response_received:
                    print(f"[FAILED] Account {xSeT.id}: No response for squad {teamcode} within {timeout} seconds")
                    return {
                        "success": False, 
                        "reason": f"لم يتم استلام رد من الخادم خلال {timeout} ثانية. تأكد من صحة رمز السكواد: {teamcode}"
                    }
            
            return {"success": False, "reason": "لا يوجد اتصال ثانوي نشط"}
            
        except Exception as e:
            print(f"[ERROR] Account {xSeT.id}: GeTinFoSqMsG error: {str(e)}")
            return {"success": False, "reason": str(e)}

    def SeNd_MsG(xSeT, client, OwNer_UiD, ChaT_CoDe, message, count=100):
        """إرسال الرسائل مع تحسين الأداء"""
        try:
            if hasattr(client, 'CliEnts') and client.CliEnts:
                client.CliEnts.send(OpenCh(OwNer_UiD, ChaT_CoDe, client.key, client.iv))
                time.sleep(0.5)
                
                for i in range(count):
                    client.CliEnts.send(MsqSq(f'[b][c]{generate_random_color()}{message}', OwNer_UiD, client.key, client.iv))
                    time.sleep(0.3)  # تقليل وقت الانتظار قليلاً
                    
        except Exception as e:
            print(f"[ERROR] Account {client.id}: SeNd_MsG error: {e}")       

    def SeNd_SpaM_MsG(xSeT, OwNer_UiD, ChaT_CoDe, message, count=100):
        """إرسال رسائل متعددة"""
        try:
            threads = []
            message_clients = list(connected_clients.values())[:3]
                
            for client in message_clients:
                thread = threading.Thread(target=xSeT.SeNd_MsG, args=(client, OwNer_UiD, ChaT_CoDe, message, count))
                threads.append(thread)
                thread.start()
            
            for thread in threads:
                thread.join(timeout=30)
                
            return True
        except Exception as e:
            print(f"[ERROR] SeNd_SpaM_MsG error: {e}")
            return False

    def cleanup_threads(xSeT):
        """تنظيف الخيوط الميتة"""
        current_time = time.time()
        xSeT.active_threads = [t for t in xSeT.active_threads 
                              if t['thread'].is_alive() and 
                              current_time - t['start_time'] < xSeT.thread_timeout]

    def ConnEcT_SerVer_OnLiNe(xSeT, Token, tok, host, port, key, iv, host2, port2):
        """الاتصال بالخادم الثانوي مع تحسين معالجة المهلات"""
        xSeT.key = key
        xSeT.iv = iv
        retry_count = 0
        max_retries = 5
        last_error_log = 0
        
        while True:
            try:
                print(f"[INFO] Account {xSeT.id}: Connecting to secondary server {host2}:{port2}")
                xSeT.CliEnts2 = socket.create_connection((host2, int(port2)), timeout=15)
                xSeT.CliEnts2.send(bytes.fromhex(tok))
                print(f"[SUCCESS] Account {xSeT.id}: Connected to secondary server")
                retry_count = 0
                
                while True:
                    try:
                        xSeT.CliEnts2.settimeout(2)  # مهلة أطول قليلاً
                        xSeT.DaTa2 = xSeT.CliEnts2.recv(65535)
                        
                        if not xSeT.DaTa2:
                            print(f"[WARNING] Account {xSeT.id}: Secondary connection closed by server")
                            break
                        
                        hex_data = xSeT.DaTa2.hex()
                        if len(hex_data) > 4 and '0500' in hex_data[:4] and len(hex_data) > 30:
                            try:
                                xSeT.packet = json.loads(DeCode_PackEt(f'08{hex_data.split("08", 1)[1]}'))
                                if '5' in xSeT.packet and 'data' in xSeT.packet['5']:
                                    if '7' in xSeT.packet['5']['data'] and 'data' in xSeT.packet['5']['data']['7']:
                                        xSeT.AutH = xSeT.packet['5']['data']['7']['data']
                                        print(f"[INFO] Account {xSeT.id}: Received auth packet")
                            except Exception as e:
                                print(f"[WARNING] Account {xSeT.id}: Error processing packet: {e}")
                                
                    except socket.timeout:
                        # لا نطبع أي شيء للمهلات المتوقعة
                        continue
                    except socket.error as e:
                        print(f"[ERROR] Account {xSeT.id}: Socket error: {e}")
                        break
                    
            except Exception as e:
                current_time = time.time()
                if current_time - last_error_log > 10:  # طباعة كل 10 ثوانٍ فقط
                    print(f"[ERROR] Account {xSeT.id}: Secondary connection failed: {e}")
                    last_error_log = current_time
                    
                retry_count += 1
                if retry_count > max_retries:
                    print(f"[CRITICAL] Account {xSeT.id}: Max retries reached. Waiting 30 seconds...")
                    time.sleep(30)
                    retry_count = 0
                else:
                    time.sleep(5)
                continue

    def ConnEcT_SerVer(xSeT, Token, tok, host, port, key, iv, host2, port2):
        """الاتصال الرئيسي بالخادم"""
        xSeT.key = key
        xSeT.iv = iv
        try:
            print(f"[INFO] Account {xSeT.id}: Connecting to main server {host}:{port}")
            xSeT.CliEnts = socket.create_connection((host, int(port)), timeout=15)
            xSeT.CliEnts.send(bytes.fromhex(tok))  
            xSeT.DaTa = xSeT.CliEnts.recv(1024)
            print(f"[SUCCESS] Account {xSeT.id}: Connected to main server")
        except Exception as e:
            print(f"[ERROR] Account {xSeT.id}: Main connection failed: {e}")
            time.sleep(5)
            xSeT.ConnEcT_SerVer(Token, tok, host, port, key, iv, host2, port2)
            return
        
        # تشغيل الاتصال الثانوي في خيط منفصل
        secondary_thread = threading.Thread(target=xSeT.ConnEcT_SerVer_OnLiNe, args=(Token, tok, host, port, key, iv, host2, port2), daemon=True)
        secondary_thread.start()
        
        xSeT.Exemple = xMsGFixinG('Fu*Ck YoU')
        while True:      
            try:
                xSeT.CliEnts.settimeout(10)
                xSeT.DaTa = xSeT.CliEnts.recv(4096)
                
                if len(xSeT.DaTa) == 0:
                    print(f"[WARNING] Account {xSeT.id}: Main connection closed")
                    try:
                        xSeT.CliEnts.close()
                        if hasattr(xSeT, 'CliEnts2') and xSeT.CliEnts2:
                            xSeT.CliEnts2.close()
                        xSeT.ConnEcT_SerVer(Token, tok, host, port, key, iv, host2, port2)
                    except:
                        ResTarT_BoT()
                
                xSeT.retry_count = 0 
                xSeT.cleanup_threads()
                
            except socket.timeout:
                # مهلة متوقعة، نستمر
                continue
            except Exception as e:
                print(f"[ERROR] Account {xSeT.id}: Connection error: {e}")
                xSeT.retry_count += 1
                
                if xSeT.retry_count >= xSeT.max_retries:
                    print(f"[CRITICAL] Account {xSeT.id}: Max retries reached. Restarting...")
                    return
                
                try:
                    if xSeT.CliEnts:
                        xSeT.CliEnts.close()
                    if hasattr(xSeT, 'CliEnts2') and xSeT.CliEnts2:
                        xSeT.CliEnts2.close()
                except:
                    pass
                time.sleep(5)
                xSeT.ConnEcT_SerVer(Token, tok, host, port, key, iv, host2, port2)

    def GeT_Key_Iv(xSeT, serialized_data):
        """استخراج المفاتيح من البيانات"""
        try:
            import xK
            my_message = xK.MyMessage()
            my_message.ParseFromString(serialized_data)
            timestamp, key, iv = my_message.field21, my_message.field22, my_message.field23
            timestamp_obj = Timestamp()
            timestamp_obj.FromNanoseconds(timestamp)
            timestamp_seconds = timestamp_obj.seconds
            timestamp_nanos = timestamp_obj.nanos
            combined_timestamp = timestamp_seconds * 1_000_000_000 + timestamp_nanos
            return combined_timestamp, key, iv            
        except Exception as e:
            print(f"[ERROR] GeT_Key_Iv: {e}")
            return None, None, None

